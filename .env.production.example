POSTGRES_PASSWORD=change-me
API_BIND=127.0.0.1
API_PORT=8899
API_AUTH_KEY=change-me-too
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VIBE_TRADING_SECRET_KEY=change-me-fernet-key
VIBE_TRADING_COOKIE_SECURE=true
VIBE_TRADING_COOKIE_SAMESITE=lax
VIBE_TRADING_COOKIE_DOMAIN=
# Keep disabled in commercial deployments. Create the first Owner with the
# src.commercial.bootstrap command, then add members in the administration console.
HYPER_TRADING_ALLOW_SELF_REGISTRATION=0
CORS_ORIGINS=https://agent.example.com
# Comma-separated bootstrap accounts for the separate system-level /platform console.
# These users must register or be created first; organization Owner/Admin roles do not grant this access.
HYPER_TRADING_PLATFORM_ADMIN_EMAILS=
VIBE_TRADING_SKIP_PREFLIGHT=1
# Keep disabled for server deployments. Enable only for Docker Desktop local use.
VIBE_TRADING_TRUST_DOCKER_LOOPBACK=0

# Public Nginx gateway ports when using docker-compose.server.yml.
HTTP_PORT=80
HTTPS_PORT=443

# Default model provider fallback. Organization-scoped providers are managed in the app.
LANGCHAIN_PROVIDER=siliconflow
LANGCHAIN_MODEL_NAME=deepseek-ai/DeepSeek-V3.2
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=

# Runtime durable job backend. Use sqlite-local for simple local deployments;
# redis-postgres enables the worker queue contract used by production compose.
HYPER_TRADING_RUNTIME_JOB_BACKEND=redis-postgres
HYPER_TRADING_RUNTIME_JOB_QUEUE=hyper:runtime:jobs

# Production vector retrieval. Keep the dimension aligned with the configured
# embedding model. SiliconFlow BAAI/bge-m3 uses 1024 dimensions.
HYPER_TRADING_VECTOR_STORAGE=postgres-pgvector
HYPER_TRADING_PGVECTOR_DIMENSIONS=1024

# Optional market data credentials.
TUSHARE_TOKEN=
